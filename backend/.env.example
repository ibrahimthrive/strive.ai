ENVIRONMENT=development

DATABASE_URL=postgresql+asyncpg://strive:strive@localhost:5432/strive

JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

OPENAI_API_KEY=sk-...
# Optional: point at an OpenAI-compatible endpoint instead of OpenAI itself,
# e.g. Gemini's compat endpoint: https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_BASE_URL=
FREE_TIER_MODEL=gpt-4o-mini
PRO_TIER_MODEL=gpt-4o
FREE_TIER_DAILY_MESSAGE_LIMIT=20

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
# Optional: leave unset until you create a Business price in Stripe.
# Business checkout returns a clear error until this is configured.
STRIPE_BUSINESS_PRICE_ID=

FRONTEND_URL=http://localhost:3000
